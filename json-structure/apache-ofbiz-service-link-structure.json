{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-ofbiz/refs/heads/main/json-structure/apache-ofbiz-service-link-structure.json",
  "name": "ServiceLink",
  "description": "Hypermedia link to a service endpoint.",
  "type": "object",
  "properties": {
    "href": {
      "type": "uri",
      "description": "URL to invoke the service.",
      "example": "https://localhost:8443/rest/services/findProductById"
    },
    "rel": {
      "type": "string",
      "description": "Relationship type.",
      "example": "self"
    },
    "type": {
      "type": "string",
      "description": "HTTP method for accessing the service.",
      "example": "get"
    }
  }
}